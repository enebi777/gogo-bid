# Copy to .env and fill in. Never commit the real .env file.

# ── Core ──
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://gogobid:gogobid_dev_only_change_me@localhost:5432/gogobid

# ── Redis / Queue ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Credential encryption (AES-256-GCM key, 32 bytes, base64) ──
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# ── Meta (Facebook) Ads — https://developers.facebook.com/apps ──
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/oauth/meta/callback
META_GRAPH_API_VERSION=v20.0

# ── Google Ads — https://console.cloud.google.com + https://ads.google.com/aw/apicenter ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/oauth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── TikTok Ads — https://ads.tiktok.com/marketing_api ──
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/oauth/tiktok/callback

# ── Affiliate Networks ──
CLICKBANK_DEV_KEY=
CLICKBANK_CLERK_KEY=
DIGISTORE24_API_KEY=

# ── Trackers (per-user keys are stored encrypted in DB, these are just for local smoke testing) ──
VOLUUM_ACCESS_ID=
VOLUUM_ACCESS_KEY=
REDTRACK_API_KEY=

# ── Postback / Webhook signing ──
POSTBACK_SHARED_SECRET=replace_with_a_long_random_string
WEBHOOK_META_VERIFY_TOKEN=
WEBHOOK_TIKTOK_VERIFY_TOKEN=

# ── AI ──
ANTHROPIC_API_KEY=
