{
  "name": "gogo-bid-backend",
  "version": "0.1.0",
  "private": true,
  "description": "GoGo Bid production backend — OAuth integrations, postback/webhook receivers, queue workers, AI services.",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "worker": "node dist/queue/worker.main.js",
    "worker:dev": "ts-node-dev --respawn src/queue/worker.main.ts",
    "scheduler": "node dist/queue/scheduler.main.js",
    "scheduler:dev": "ts-node-dev src/queue/scheduler.main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --testPathIgnorePatterns=e2e-spec",
    "test:e2e": "jest --testPathPatterns=e2e-spec --runInBand"
  },
  "jest": {
    "rootDir": "src",
    "testEnvironment": "node",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "testRegex": "\\.(spec|e2e-spec)\\.ts$"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.19.0",
    "axios": "^1.7.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-ads-api": "^17.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.19.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
